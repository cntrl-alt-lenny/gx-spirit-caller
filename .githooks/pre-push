#!/usr/bin/env bash
# pre-push — run tools/check_match_invariants.py and block the push
# if it reports errors. Caught #135's .c-listed-but-.s-on-disk
# mismatch before CI instead of after.
#
# Scope: blocks on errors (exit code 2) only. Warnings (exit 1) are
# expected — 317 complete_tu_rename warnings on current main are a
# pre-existing backlog, not new.
#
# Install: `python tools/install_git_hooks.py` from project root.
# Bypass once: `git push --no-verify` (standard git flag).
# Skip permanently: `git config core.hooksPath ""` (unset the path).
#
# This hook is committed to the repo at .githooks/ and activated
# via core.hooksPath by the installer; it's not at .git/hooks/
# (untracked). That's by design — the hook's behaviour stays
# consistent across clones.

set -euo pipefail

# Fast-path: skip if no config/ or src/ changes are being pushed.
# check_match_invariants only reads those directories, so a docs/
# or tools/-only push can't move the needle.
#
# stdin for pre-push is the ref-update manifest:
#   <local_ref> <local_sha> <remote_ref> <remote_sha> ...
# We'll iterate refs, compute the diff range, and cheap-filter.

touched_interesting=0
while read -r local_ref local_sha remote_ref remote_sha; do
    # Deletion (local_sha is all zeroes) — nothing to check.
    if [[ "${local_sha}" == "0000000000000000000000000000000000000000" ]]; then
        continue
    fi

    # New branch (remote_sha is zeros): diff against merge base
    # with origin/main, falling back to the parent commit if no
    # origin/main.
    if [[ "${remote_sha}" == "0000000000000000000000000000000000000000" ]]; then
        base=$(git merge-base "${local_sha}" origin/main 2>/dev/null \
               || git rev-parse "${local_sha}^" 2>/dev/null \
               || echo "")
    else
        base="${remote_sha}"
    fi

    if [[ -z "${base}" ]]; then
        # Couldn't resolve a base — run the check conservatively.
        touched_interesting=1
        break
    fi

    # Cheap file-path grep. `git diff --name-only` lists changed
    # files between base and head.
    if git diff --name-only "${base}" "${local_sha}" 2>/dev/null \
            | grep -qE '^(config/|src/|tools/check_match_invariants\.py)'; then
        touched_interesting=1
        break
    fi
done

if [[ "${touched_interesting}" -eq 0 ]]; then
    # Nothing the invariants care about.
    exit 0
fi

# Locate python. Support PYTHON env override for repos with pinned
# interpreters.
PYTHON="${PYTHON:-python3}"
if ! command -v "${PYTHON}" >/dev/null 2>&1; then
    echo "pre-push: ${PYTHON} not found; skipping invariants check." >&2
    echo "pre-push: set PYTHON=<path> or install Python to enable." >&2
    exit 0
fi

# Run the check. --version eur is hardcoded (project baseline);
# multi-version support would extend this to a loop.
if ! "${PYTHON}" tools/check_match_invariants.py --version eur \
        >/tmp/invariants.out 2>&1; then
    rc=$?
    if [[ "${rc}" -eq 2 ]]; then
        echo >&2
        echo "❌ pre-push: match-invariants reports ERRORS." >&2
        echo "   Pushing would break CI. Fix first." >&2
        echo >&2
        # Show ONLY the error section to avoid flooding the terminal
        # with the (expected) 300+ complete_tu_rename warnings.
        awk '
            /^== [a-z_]+ \([0-9]+\) ==$/ { section=$0; hide=0 }
            /^== complete_tu_rename / { hide=1 }
            hide==0 { print }
        ' /tmp/invariants.out >&2
        echo >&2
        echo "Bypass once: git push --no-verify" >&2
        exit 1
    fi
    # rc=1 (warnings only) — let it through.
fi

exit 0
